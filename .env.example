# Copy this file to ".env" and paste your keys. Anything left blank keeps that
# feature in safe demo mode; filling it in switches the feature on — no code changes.
# After editing .env, restart `npm run dev`.

# --- Firebase (Auth + Firestore database + push) ---------------------------
# Firebase console → Project settings → Your apps → Web app → SDK setup & config
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef

# --- Push notifications (FCM) ----------------------------------------------
# Firebase console → Project settings → Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=your-vapid-key

# --- Google Maps (Store Locator live map) ----------------------------------
# Google Cloud console → APIs & Services → Credentials → API key (enable "Maps JavaScript API")
VITE_GOOGLE_MAPS_API_KEY=your-maps-key

# --- Wallet passes backend (Apple / Google / Samsung) ----------------------
# Deploy functions/ then paste the URL (e.g. https://<region>-<project>.cloudfunctions.net/api)
VITE_WALLET_API_URL=
